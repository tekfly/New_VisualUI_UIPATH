<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="UiPath Enterprise Robot Installer Tool"
    Width="1024"
    Height="800"
    MaxHeight="850"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto" RenderTransformOrigin="0.5,0.5">
        <ScrollViewer.RenderTransform>
            <TransformGroup>
                <ScaleTransform/>
                <SkewTransform AngleX="0.122"/>
                <RotateTransform/>
                <TranslateTransform X="0.798"/>
            </TransformGroup>
        </ScrollViewer.RenderTransform>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Text="ABP UiPath Custom Installer"
                       FontSize="26" FontWeight="Bold" Margin="0 0 0 16"/>

            <!-- ======== SCREEN 1: Download & Verify ======== -->
            <Grid x:Name="Screen1Grid" Grid.Row="1" Visibility="Visible">
                <StackPanel Orientation="Vertical" VerticalAlignment="Top">
                    <GroupBox Header="Online Download (optional)" Margin="0 0 0 20">
                        <Expander Width="Auto" IsExpanded="True" Margin="2,0,2,2">
                            <StackPanel Margin="12">
                                <TextBlock Text="If this machine has internet, select the product(s)/version(s) to download. Selections are populated from json_files (falls back to GitHub if the local files are missing/empty). Each file will be saved into the selected target folder."
                                           TextWrapping="Wrap" Margin="0 0 0 10"/>

                                <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                                    <TextBlock Text="Main Products:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Button x:Name="UpdateJsonBtn" Content="Update Version Lists (GitHub)" Width="220" Margin="16 0 0 0"/>
                                    <TextBlock x:Name="UpdateJsonStatus" Margin="10 0 0 0" VerticalAlignment="Center" Foreground="DimGray"/>
                                </StackPanel>
                                <StackPanel x:Name="MainPairsPanel"/>
                                <Button x:Name="AddMainPairBtn" Content="Add another product" Width="180" Margin="0 6 0 10"/>

                                <CheckBox x:Name="EnableExtraProductsCheck" Content="Download extra products" Margin="0 4 0 4"/>
                                <StackPanel x:Name="ExtraProductsSection" Visibility="Collapsed">
                                    <TextBlock Text="Extra Products:" FontWeight="SemiBold" Margin="0 4 0 6"/>
                                    <StackPanel x:Name="ExtraPairsPanel"/>
                                    <Button x:Name="AddExtraPairBtn" Content="Add extra product" Width="180" Margin="0 6 0 10"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0 10 0 0">
                                    <TextBlock Text="Target folder:" Width="120" VerticalAlignment="Center"/>
                                    <TextBox x:Name="DownloadTargetBox" Width="600"/>
                                    <Button x:Name="BrowseDownloadTargetBtn" Content="Browse" Width="90" Margin="10 0 0 0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0 10 0 0">
                                    <Button x:Name="DownloadBtn" Content="Download Installer Files" Width="220"/>
                                    <ProgressBar x:Name="DownloadProgress" Width="300" Height="18" Margin="12 0 0 0"/>
                                    <TextBlock x:Name="DownloadStatus" Margin="10 0 0 0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Expander>
                    </GroupBox>

                    <!-- OFFLINE VALIDATION -->
                    <GroupBox Header="Offline Files (select an existing folder)" Margin="0 0 0 20">
                        <StackPanel Margin="12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Installer folder:" Width="120" VerticalAlignment="Center"/>
                                <TextBox x:Name="InstallerFolderBox" Width="600"/>
                                <Button x:Name="BrowseInstallerFolderBtn" Content="Browse" Width="90" Margin="10 0 0 0"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0 10 0 0">
                                <TextBlock Text="Expected SHA256 (optional):" Width="180" VerticalAlignment="Center"/>
                                <TextBox x:Name="ExpectedShaBox" Width="520"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0 10 0 0">
                                <Button x:Name="ValidateInstallerBtn" Content="Validate Files" Width="160"/>
                                <TextBlock x:Name="InstallerValidationResult" Margin="12 0 0 0" VerticalAlignment="Center" Foreground="DarkBlue"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- INSTALLED SOFTWARE CHECK -->
                    <GroupBox Header="Check Installed UiPath Software" Margin="0 0 0 20">
                        <StackPanel Margin="12">
                            <TextBlock Text="Scans this machine's installed-programs registry and common install folders for any UiPath component already present."
                                       TextWrapping="Wrap" Margin="0 0 0 10"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="CheckInstalledBtn" Content="Check Installed UiPath Software" Width="240"/>
                            </StackPanel>
                            <TextBox x:Name="InstalledSoftwareResult"
                                     Margin="0 10 0 0"
                                     Height="120"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- NEXT -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="NextToInstallBtn" Content="Next → Installation" Width="180" IsEnabled="False"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ======== SCREEN 2: Installation & Configuration ======== -->
            <Grid x:Name="Screen2Grid" Grid.Row="1" Visibility="Collapsed">
                <StackPanel Orientation="Vertical" VerticalAlignment="Top">

                    <!-- NAV -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0 0 0 8">
                        <Button x:Name="BackToScreen1Btn" Content="← Back" Width="90"/>
                        <TextBlock Text="Proceed with installation and configuration" Margin="10 6 0 0" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Installation Mode -->
                    <GroupBox Header="Installation Mode" Margin="0 0 0 18">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Left -->
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <CheckBox x:Name="ServiceModeCheck" Content="Install in Service Mode" IsChecked="True"/>
                                <CheckBox x:Name="AllUsersCheck" Content="Install for All Users" IsChecked="True"/>
                            </StackPanel>

                            <!-- Right: component selection -->
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <CheckBox x:Name="RobotInstallCheck" Content="Install Robot" IsChecked="True"/>
                                <CheckBox x:Name="StudioInstallCheck" Content="Install Studio" IsChecked="False"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- INSTALL PATH -->
                    <GroupBox Header="Installation Path" Margin="0 0 0 18">
                        <GroupBox.Resources>
                            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
                        </GroupBox.Resources>
                        <StackPanel Margin="12">
                            <RadioButton x:Name="DefaultPathRadio" Content="Use Default Path" IsChecked="True"/>
                            <CheckBox x:Name="CustomInstallationPath" Content="Custom installation Path" Margin="0 5 0 0"/>
                            <StackPanel Orientation="Horizontal"
                                        Margin="20 6 0 0"
                                        Visibility="{Binding IsChecked, Converter={StaticResource BoolToVis}, ElementName=CustomInstallationPath}">
                                <RadioButton x:Name="CustomPathRadio" Content="Custom Path" Margin="0 0 10 0" VerticalAlignment="Center"/>
                                <TextBox x:Name="CustomPathBox" Width="540" VerticalAlignment="Center"/>
                                <Button x:Name="BrowseCustomPathBtn" Content="Browse" Width="90" Margin="10 0 0 0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- Browser Extensions -->
                    <GroupBox Header="Browser Extension" Margin="0 0 0 18">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Left -->
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <CheckBox x:Name="ChromeExtCheck" Content="Install Chrome Extension" IsChecked="True"/>
                                <CheckBox x:Name="EdgeExtCheck" Content="Install Edge Extension" IsChecked="True"/>
                                <CheckBox x:Name="FirefoxExtCheck" Content="Install Firefox Extension" IsChecked="False"/>
                            </StackPanel>

                            <!-- Right -->
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <CheckBox x:Name="JavaExtCheck" Content="Install Java Extension" IsChecked="False"/>
                                <CheckBox x:Name="CitrixExtCheck" Content="Install Citrix Extension" IsChecked="False"/>
                                <CheckBox x:Name="WinRemoteExtCheck" Content="Install Windows Remote Desktop Extension" IsChecked="False"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- Orchestrator Auto-Configuration -->
                    <GroupBox Header="Orchestrator Auto-Configuration (Connect)" Margin="0 0 0 18">
                        <Expander Width="Auto" IsExpanded="False" Margin="2,0,2,2">
                            <StackPanel Margin="12">
                                <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                    <TextBlock Text="Orchestrator URL:" Width="180"/>
                                    <TextBox x:Name="OrchUrlBox" Width="600"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                    <TextBlock Text="Machine Key / Client ID:" Width="180"/>
                                    <TextBox x:Name="MachineKeyBox" Width="600"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                    <TextBlock Text="Client Secret:" Width="180"/>
                                    <TextBox x:Name="ClientSecretNameBox" Width="600"/>
                                </StackPanel>
                                <CheckBox x:Name="ConnectAfterInstallCheck" Content="Connect Robot After Installation" Margin="0 10 0 0" IsChecked="False"/>
                            </StackPanel>
                        </Expander>
                    </GroupBox>

                    <!-- LOG CONFIG (NLog) -->
                    <GroupBox Header="Log Configuration (NLog)" Margin="0 0 0 18">
                        <StackPanel Margin="12">
                            <CheckBox x:Name="EnableLogConfigCheck"
                                      Content="Enable log configuration"
                                      IsChecked="False"/>
                            <StackPanel x:Name="LogConfigPanel" Margin="0 8 0 0" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal" Margin="0 6 0 0">
                                    <TextBlock Text="Delete logs older than:" Width="180"/>
                                    <TextBox x:Name="LogDaysBox" Width="80" IsEnabled="False"/>
                                    <TextBlock Text="days" Margin="6 0 0 0"/>
                                    <Button x:Name="CleanLogsBtn" Content="Clean Logs Now" Width="150" Margin="12 0 0 0" IsEnabled="False"/>
                                </StackPanel>
                                <CheckBox x:Name="UseCustomLogFolderCheck"
                                          Content="Use custom log folder (edit NLog.config)"
                                          Margin="0 12 0 0"
                                          IsChecked="False"/>
                                <StackPanel x:Name="CustomLogFolderPanel" Margin="0 6 0 0" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Custom Log Folder:" Width="180"/>
                                        <TextBox x:Name="LogFolderBox" Width="520"/>
                                        <Button x:Name="BrowseLogFolderBtn" Content="Browse" Width="90"/>
                                    </StackPanel>
                                    <Button x:Name="ApplyNLogBtn" Content="Apply NLog Settings" Margin="0 10 0 0" Width="190"/>
                                    <TextBlock Text="Note: Log storage behavior differs between Service Mode (LocalSystem profile) and User Mode. Adjust the folder accordingly."
                                               Foreground="DimGray" Margin="0 6 0 0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- SCRIPT -->
                    <GroupBox Header="Generated PowerShell Script" Margin="0 0 0 12">
                        <StackPanel Margin="12">
                            <TextBox x:Name="ScriptOutputBox"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     AcceptsReturn="True"
                                     Height="260"/>
                            <StackPanel Orientation="Horizontal" Margin="0 10 0 0">
                                <Button x:Name="GenerateScriptBtn" Content="Generate Script" Width="150"/>
                                <Button x:Name="CopyScriptBtn" Content="Copy" Width="90" Margin="10 0 0 0"/>
                                <Button x:Name="SaveScriptBtn" Content="Save to File" Width="130" Margin="10 0 0 0"/>
                                <Button x:Name="RunInstallerBtn" Content="Run Installer" Width="150" Margin="10 0 0 0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- PROGRESS OVERLAY (Screen 2) -->
                    <Grid x:Name="InstallProgressOverlay" Background="#88000000" Visibility="Collapsed">
                        <Border Background="White"
                                CornerRadius="6"
                                Padding="16"
                                Width="520"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock x:Name="InstallProgressTitle"
                                           Text="Running installer..."
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <TextBlock x:Name="InstallProgressStep"
                                           Text="Preparing..."
                                           Margin="0,0,0,8"/>
                                <ProgressBar x:Name="InstallProgressBar"
                                             Height="16"
                                             IsIndeterminate="True"/>
                                <TextBlock Text="Details:" Margin="0,12,0,4" FontWeight="SemiBold"/>
                                <TextBox x:Name="InstallProgressLog"
                                         Height="160"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                    <Button x:Name="CancelInstallBtn" Content="Cancel" Width="90"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>

        </Grid>
    </ScrollViewer>
</Window>